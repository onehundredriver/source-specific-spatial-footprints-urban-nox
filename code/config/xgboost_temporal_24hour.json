    "feature_list_column": "筛选后的自变量",
    "split_timestamp_column": "Timestamp",
    "split_fold_column": "Temporal_Fold"
  },
  "temporal_cv": {
    "n_folds": 5,
    "validation_rule": "Temporal_Fold == current_fold",
    "training_rule": "Temporal_Fold != current_fold",
