{
  "experiment_id": "xgboost_temporal_24hour",
  "model_family": "XGBoost",
  "cv_type": "temporal_5fold_by_timestamp",
  "time_scale": "24hour",
  "paths": {
    "model_input_file": "data/model_inputs/modeling_dataset_24hour.parquet",
